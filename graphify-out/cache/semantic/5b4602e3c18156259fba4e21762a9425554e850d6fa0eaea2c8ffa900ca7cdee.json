{"nodes": [{"id": "adr0004_backflow_execution", "label": "Backflow Execution", "file_type": "rationale", "source_file": "docs/adr/0004-backflow-execution.md", "source_location": "Decision", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Downstream-only commits are replayed to one authoritative source branch using deterministic, convergent Git and forge state."}, {"id": "adr0004_deterministic_return_branch", "label": "Deterministic Backflow Return Branch", "file_type": "rationale", "source_file": "docs/adr/0004-backflow-execution.md", "source_location": "Decision O4", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A fixed-length source-head-keyed oiax/backflow branch makes repeated and racing runs converge while a new hotfix creates a distinct reviewable request."}, {"id": "adr0004_event_driven_concurrency", "label": "Event-Driven Concurrency Without Locks", "file_type": "rationale", "source_file": "docs/adr/0004-backflow-execution.md", "source_location": "Context and Consequences", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Correctness depends on deterministic state and ancestry guards rather than event ordering or locks because runs can overlap, duplicate, or be missed."}, {"id": "adr0004_identity_ladder", "label": "Backflow Identity Ladder", "file_type": "rationale", "source_file": "docs/adr/0004-backflow-execution.md", "source_location": "Execution mechanics: Identity ladder", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Cherry-pick provenance, stable patch identity, and a manual skip trailer determine whether downstream content is already represented on target."}, {"id": "adr0004_o6_skip_trailer", "label": "Oiax-Backflow Skip Trailer", "file_type": "rationale", "source_file": "docs/adr/0004-backflow-execution.md", "source_location": "Decision O6", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A commit-local manual escape hatch suppresses intentional downstream-only changes without introducing an Oiax state database."}, {"id": "adr0004_ephemeral_worktree", "label": "Ephemeral Detached Worktree Replay", "file_type": "rationale", "source_file": "docs/adr/0004-backflow-execution.md", "source_location": "Execution mechanics: Isolation", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Detached temporary worktrees isolate cherry-picks from the caller's checkout and index and are cleaned on every exit path."}, {"id": "adr0004_conflict_divergence", "label": "Backflow Conflict as Reported Divergence", "file_type": "rationale", "source_file": "docs/adr/0004-backflow-execution.md", "source_location": "Execution mechanics: Conflict handling", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A genuine content conflict produces exit 3 with actionable commit context and no push; operational failures remain ordinary errors."}, {"id": "adr0004_supersede_stale_request", "label": "Supersede Stale Backflow Request", "file_type": "rationale", "source_file": "docs/adr/0004-backflow-execution.md", "source_location": "Execution mechanics: At most one active request", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A newer source head closes only ancestry-proven stale managed requests and opens a new request rather than rewriting already-reviewed history."}], "edges": [{"source": "adr0004_backflow_execution", "target": "adr0002_content_divergence", "relation": "cites", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/adr/0004-backflow-execution.md", "source_location": "Context", "weight": 1.0}, {"source": "adr0004_backflow_execution", "target": "adr0003_pinned_ref", "relation": "cites", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/adr/0004-b